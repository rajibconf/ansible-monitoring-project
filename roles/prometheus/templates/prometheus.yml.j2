global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node_exporter'
    static_configs:
{% if groups['exporters'] is defined %}
{% for host in groups['exporters'] %}
      - targets: ['{{ hostvars[host].ansible_host | default(host) }}:9100']
{% endfor %}
{% endif %}
